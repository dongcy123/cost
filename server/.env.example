# Neon PostgreSQL connection string
DATABASE_URL=postgresql://user:password@ep-xxx.us-east-1.aws.neon.tech/icost?sslmode=require

# DeepSeek API (Anthropic-compatible)
ANTHROPIC_BASE_URL=https://api.deepseek.com/anthropic
ANTHROPIC_AUTH_TOKEN=sk-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
ANTHROPIC_MODEL=deepseek-v4-pro[1m]

# Baidu OCR API (https://console.bce.baidu.com/ai/#/ai/ocr/overview/index)
BAIDU_API_KEY=your_baidu_api_key_here
BAIDU_SECRET_KEY=your_baidu_secret_key_here
